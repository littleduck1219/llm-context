{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist/cli",
    "rootDir": "./src/cli",
    "strict": false,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "types": ["node"]
  },
  "include": ["src/cli/**/*"],
  "exclude": ["node_modules"]
}
